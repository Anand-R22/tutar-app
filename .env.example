# ============================================
# TutAR Environment Variables
# 
# INSTRUCTIONS:
# 1. Copy this file and rename it to: .env
# 2. Fill in your actual API keys below
# 3. Never share this .env file with anyone
# ============================================

# HuggingFace API Key
# Get from: https://huggingface.co → Settings → Access Tokens
HUGGINGFACE_API_KEY=hf_your_key_here

# Pinecone API Key
# Get from: https://app.pinecone.io → API Keys
PINECONE_API_KEY=your_pinecone_key_here

# Pinecone Index Name (must match what you created)
PINECONE_INDEX=tutar-models
